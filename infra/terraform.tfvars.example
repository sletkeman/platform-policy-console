aws_region            = "us-east-1"
project_name          = "platform-policy-console"
environment           = "dev"
image_tag             = "latest"
instance_type         = "t3.micro"
log_level             = "info"
acm_certificate_arn   = null
service_hostname      = null
github_webhook_secret = "replace-with-a-strong-shared-secret"
github_token          = null

policy_events_visibility_timeout_seconds = 60
policy_events_retention_seconds          = 345600
policy_events_max_receive_count          = 5
